{
  "name": "techsinno-dashboard",
  "version": "2.0.0",
  "description": "TECHSINNO Business Dashboard — Frank Muland",
  "main": "Techsinno_DashBoard.js",
  "scripts": {
    "start": "electron Techsinno_DashBoard.js",
    "start:web": "node web-server.js",
    "build": "electron-builder --win --x64",
    "api": "cd api && func start",
    "dev": "concurrently \"npm run api\" \"npm run start:web\""
  },
  "build": {
    "appId": "co.za.techsinno.dashboard",
    "productName": "TECHSINNO Dashboard",
    "files": [
      "Techsinno_DashBoard.js",
      "preload.js",
      "web-server.js",
      "src/**",
      "web/**",
      "assets/**",
      "node_modules/**"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "concurrently": "^8.0.0",
    "electron": "^28.3.3",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "axios": "^1.6.0",
    "electron-store": "^8.1.0",
    "express": "^4.18.0"
  }
}
