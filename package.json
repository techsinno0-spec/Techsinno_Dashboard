{
  "name": "techsinno-dashboard",
  "version": "1.0.0",
  "description": "TECHSINNO Business Dashboard — Frank Muland",
  "main": "Techsinno_DashBoard.js",
  "scripts": {
    "start": "node -e \"delete process.env.ELECTRON_RUN_AS_NODE;require('child_process').spawnSync(require('electron'),['.'],{stdio:'inherit',env:process.env})\"",
    "build": "electron-builder --win --x64"
  },
  "build": {
    "appId": "co.za.techsinno.dashboard",
    "productName": "TECHSINNO Dashboard",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "axios": "^1.6.0",
    "electron-store": "^8.1.0",
    "express": "^4.18.0"
  }
}
